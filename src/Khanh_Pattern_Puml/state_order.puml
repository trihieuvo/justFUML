@startuml
skinparam ClassAttributeIconSize 0

' --- State Interface ---
interface OrderState <<State>> {
    + processOrder(context : OrderContext)
    + shipOrder(context : OrderContext)
    + deliverOrder(context : OrderContext)
    + cancelOrder(context : OrderContext, reason : String)
}

' --- Context ---
class OrderContext <<Context>> {
    - order : Order
    - state : OrderState
    - notificationService : OrderNotificationService
    - restockService : RestockService
    --
    + OrderContext(order : Order)
    + setState(state : OrderState)
    + processOrder()
    + shipOrder()
    + deliverOrder()
    + cancelOrder(reason : String)
}

' --- Concrete States ---
class PendingState <<ConcreteState>> {
    + processOrder(context : OrderContext)
    + cancelOrder(context : OrderContext, reason : String)
}

class ProcessingState <<ConcreteState>> {
    + shipOrder(context : OrderContext)
    + cancelOrder(context : OrderContext, reason : String)
}

class ShippedState <<ConcreteState>> {
    + deliverOrder(context : OrderContext)
    + cancelOrder(context : OrderContext, reason : String)
}

class DeliveredState <<ConcreteState>> {
}

class CancelledState <<ConcreteState>> {
}

' --- Relationships ---
OrderContext o--> "1" OrderState : "current_state"
OrderContext o--> "1" Order : "holds"
OrderState <|.. PendingState : "implements"
OrderState <|.. ProcessingState : "implements"
OrderState <|.. ShippedState : "implements"
OrderState <|.. DeliveredState : "implements"
OrderState <|.. CancelledState : "implements"

' --- Data Entities (Abbreviated) ---
class Order {
    - id : Long
    - orderCode : String
    - status : OrderStatus
    - totalAmount : BigDecimal
    - ...
}

' --- State Transitions (Optional hints) ---
PendingState ..> ProcessingState : "<<creates>>"
ProcessingState ..> ShippedState : "<<creates>>"
ShippedState ..> DeliveredState : "<<creates>>"
PendingState ..> CancelledState : "<<creates>>"

' --- Notes ---
note left of OrderContext::state
  Lưu trữ trạng thái hiện tại.
  Mọi hành động như processOrder() 
  đều ủy quyền (delegate) qua:
  this.state.processOrder(this)
end note

note right of PendingState::processOrder
  Chuyển cảnh (Transition):
  1. Cập nhật Order.status
  2. Dùng context.setState(new ProcessingState())
  3. Gửi Email thông báo
end note

@enduml
