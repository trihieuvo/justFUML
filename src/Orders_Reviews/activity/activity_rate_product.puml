@startuml
!theme plain
skinparam linetype ortho
skinparam ActivityBackgroundColor #f9f9f9
skinparam ActivityBorderColor #333333

title Activity Diagram - Đánh giá sản phẩm (Java Servlet & JPA)

|Người dùng|
start
:Truy cập trang "Lịch sử đơn hàng" (tab Đã giao)\nhoặc "Chi tiết sản phẩm";
:Nhấn nút "Đánh giá / Viết nhận xét";
:Chọn số sao (1-5)\nvà nhập bình luận (Comment);
:Nhấn "Gửi đánh giá";

|Hệ thống|
:ReviewServlet nhận yêu cầu POST\n(kèm userId, productId, rating, comment);
:Khởi tạo EntityManager;
:Bắt đầu Transaction\n(em.getTransaction().begin());

:Kiểm tra Validation đầu vào;
if (Rating có từ 1 đến 5 sao\nvà Comment <= 1000 ký tự?) then (Không)
  :Rollback Transaction;
  :Ném ngoại lệ "Dữ liệu không hợp lệ";
  |Người dùng|
  :Hiển thị thông báo lỗi\n(VD: Đánh giá phải từ 1-5 sao);
  stop
else (Có)
  |Hệ thống|
  :Truy vấn kiểm tra điều kiện mua hàng\n(OrderDAO.checkPurchasedAndDelivered);
  note right
    Kiểm tra xem User có Order nào chứa
    Product này và có status = 'DELIVERED'
    hay không.
  end note

  if (Đã mua & Đơn hàng đã DELIVERED?) then (Không)
    :Rollback Transaction;
    :Ném ngoại lệ "Bạn chưa sở hữu sản phẩm này";
    |Người dùng|
    :Hiển thị thông báo lỗi cảnh báo;
    stop
  else (Có)
    |Hệ thống|
    :Khởi tạo đối tượng Review mới;
    :Gắn đối tượng User, Product,\nRating và Comment vào Review;

    :Lưu Đánh giá vào DB\n(ReviewDAO.persist(review));
    :Commit Transaction\n(em.getTransaction().commit());

    :Tính toán lại điểm đánh giá trung bình\ncủa Sản phẩm (Tùy chọn/Async);

    :Trả về kết quả thành công\n(HTTP 201 Created);

    |Người dùng|
    :Đóng modal/form đánh giá;
    :Hiển thị thông báo "Đánh giá thành công";
    :Giao diện load lại danh sách Review\nđể hiển thị đánh giá vừa tạo;
    stop
  endif
endif

@enduml