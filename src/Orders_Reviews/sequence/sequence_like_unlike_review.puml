@startuml
!theme plain
autonumber
skinparam SequenceMessageAlign center
skinparam ParticipantPadding 20
skinparam BoxPadding 10
skinparam linetype ortho

title Sequence Diagram - Like/Unlike Bình luận (Java Servlet & JPA)

actor "Thành viên (User)" as User
boundary "Giao diện (UI)" as UI
control "ReviewServlet" as Servlet
control "ReviewService" as Service
entity "ReviewDAO" as ReviewDAO
entity "ReviewLikeDAO" as LikeDAO
database "Database" as DB

User -> UI : Nhấn nút "Thích" (Like) \ntrên một đánh giá
activate UI

UI -> Servlet : AJAX POST /api/v1/reviews/{reviewId}/like
activate Servlet

Servlet -> Servlet : Trích xuất reviewId từ URL\nLấy userId từ Session/JWT Token

Servlet -> Service : toggleLike(userId, reviewId)
activate Service

Service -> Service : em.getTransaction().begin()

' --- KIỂM TRA REVIEW TỒN TẠI ---
Service -> ReviewDAO : findById(reviewId)
activate ReviewDAO
ReviewDAO -> DB : SELECT * FROM reviews WHERE id = ?
activate DB
DB --> ReviewDAO : review Entity
deactivate DB
ReviewDAO --> Service : review Entity
deactivate ReviewDAO

alt Nếu Đánh giá không tồn tại
    Service -> Service : em.getTransaction().rollback()
    Service --> Servlet : throw CustomException("Không tìm thấy đánh giá")
    Servlet --> UI : HTTP 404 Not Found
    UI --> User : Hiển thị thông báo lỗi
else Đánh giá hợp lệ
    ' --- KIỂM TRA TRẠNG THÁI LIKE HIỆN TẠI ---
    Service -> LikeDAO : findByUserAndReview(userId, reviewId)
    activate LikeDAO
    LikeDAO -> DB : SELECT * FROM review_likes \nWHERE user_id = ? AND review_id = ?
    activate DB
    DB --> LikeDAO : reviewLike Entity (hoặc null)
    deactivate DB
    LikeDAO --> Service : existingLike
    deactivate LikeDAO

    alt Nếu đã Like (existingLike != null) -> Thực hiện UNLIKE
        Service -> LikeDAO : remove(existingLike)
        activate LikeDAO
        LikeDAO -> DB : DELETE FROM review_likes WHERE id = ?
        activate DB
        DB --> LikeDAO : Success
        deactivate DB
        LikeDAO --> Service : Success
        deactivate LikeDAO

        Service -> Service : isLiked = false

    else Nếu chưa Like (existingLike == null) -> Thực hiện LIKE
        Service -> Service : Lấy User entity (em.getReference)\nKhởi tạo: new ReviewLike(user, review)

        Service -> LikeDAO : persist(newReviewLike)
        activate LikeDAO
        LikeDAO -> DB : INSERT INTO review_likes (user_id, review_id, created_at)
        activate DB
        DB --> LikeDAO : Success
        deactivate DB
        LikeDAO --> Service : Success
        deactivate LikeDAO

        Service -> Service : isLiked = true
    end

    ' --- LƯU & TRẢ VỀ KẾT QUẢ ---
    Service -> Service : em.getTransaction().commit()

    Service -> LikeDAO : countLikesByReviewId(reviewId)
    activate LikeDAO
    LikeDAO --> Service : totalLikes
    deactivate LikeDAO

    Service --> Servlet : Trả về LikeResponseDTO\n(isLiked, totalLikes)
    deactivate Service

    Servlet -> Servlet : Parse DTO thành JSON
    Servlet --> UI : HTTP 200 OK (Kèm JSON)
    deactivate Servlet

    UI --> User : Cập nhật UI (Đổi màu nút Like\nvà cập nhật tổng số lượt thích)
    deactivate UI
end

@enduml