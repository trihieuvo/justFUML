@startuml
!theme plain
skinparam linetype ortho
skinparam ActivityBackgroundColor #f9f9f9
skinparam ActivityBorderColor #333333

title Activity Diagram - Luồng Quản lý đơn hàng (Admin - MVC Improved)

|Admin|
start
:Truy cập danh sách đơn hàng;
:Chọn đơn hàng cần xử lý;
:Kiểm tra chi tiết đơn hàng;
note right
    - Thông tin khách hàng
    - Trạng thái thanh toán
    - Kiểm tra tồn kho thực tế
end note

if (Đơn hàng hợp lệ?) then (Có)
    :Xác nhận đơn hàng (Duyệt);
    |Hệ thống|
    :Cập nhật trạng thái **PROCESSING**;
    :Gửi Email thông báo "Đang xử lý";

    |Admin|
    :Đóng gói & Giao cho đơn vị vận chuyển;
    :Cập nhật trạng thái giao hàng;

    |Hệ thống|
    :Cập nhật trạng thái **SHIPPED**;
    :Gửi Email thông báo "Đang giao hàng";

    |Admin|
    :Theo dõi lộ trình vận chuyển;

    if (Kết quả giao hàng?) then (Thành công)
        :Xác nhận Hoàn thành;
        |Hệ thống|
        :Cập nhật trạng thái **DELIVERED**;
        :Gửi Email cảm ơn & xác nhận nhận hàng;
    else (Thất bại/Khách từ chối)
        :Xác nhận Đơn hàng bị hoàn trả;
        |Hệ thống|
        :Cập nhật trạng thái **CANCELLED**;
        :Cộng lại số lượng vào tồn kho (Restock);
        :Gửi Email thông báo hủy đơn;
    endif

else (Không)
    |Admin|
    :Từ chối đơn hàng;
    :Nhập lý do hủy đơn;
    |Hệ thống|
    :Cập nhật trạng thái **CANCELLED**;
    :Cộng lại số lượng vào tồn kho (Restock);
    :Gửi Email thông báo lý do hủy cho khách;
endif

stop
@enduml