@startuml
!theme plain
skinparam linetype ortho
skinparam ActivityBackgroundColor #f9f9f9
skinparam ActivityBorderColor #333333

title Activity Diagram - Quản lý Sản phẩm (Thêm/Sửa)

' Định nghĩa các Làn (Swimlanes) mô phỏng mô hình ECB
|Actor (Quản trị viên)|
|Boundary (Giao diện UI)|
|Control (Xử lý Hệ thống)|
|Entity (Cơ sở dữ liệu)|

|Actor (Quản trị viên)|
start
:Truy cập trang Quản lý Sản phẩm;

if (Hành động mong muốn?) then (Thêm mới)
  |Boundary (Giao diện UI)|
  :Hiển thị Form "Thêm Sản phẩm" trống;
else (Sửa Sản phẩm)
  |Control (Xử lý Hệ thống)|
  :Lấy thông tin Sản phẩm hiện tại\ncùng danh sách Category & Brand;
  |Entity (Cơ sở dữ liệu)|
  :Truy xuất dữ liệu;
  |Boundary (Giao diện UI)|
  :Hiển thị Form với dữ liệu đã điền sẵn;
endif

|Actor (Quản trị viên)|
repeat
  :Nhập/Cập nhật thông tin cơ bản\n(Tên, Giá, Số lượng, Mô tả);
  :Chọn danh mục (Category) và\nthương hiệu (Brand);
  :Tải lên Ảnh đại diện (Thumbnail);
  :Tải lên các Ảnh chi tiết (ProductImage);
  :Nhấn nút "Lưu (Save)";

  |Boundary (Giao diện UI)|
  :Đóng gói dữ liệu (Submit Form)\ngửi lên máy chủ;

  |Control (Xử lý Hệ thống)|
  :Kiểm tra tính hợp lệ cơ bản\n(Giá > 0, Tồn kho >= 0, Field trống...);

  if (Dữ liệu hợp lệ?) then (Không)
    :Tạo thông báo lỗi Validation;
    |Boundary (Giao diện UI)|
    :Hiển thị cảnh báo lỗi trên Form;
  else (Có)
    |Control (Xử lý Hệ thống)|
    :Xác thực Category và Brand\ncó tồn tại trong hệ thống không;

    if (Khóa ngoại hợp lệ?) then (Không)
      :Tạo thông báo "Không tìm thấy\nDanh mục/Thương hiệu";
      |Boundary (Giao diện UI)|
      :Hiển thị cảnh báo lỗi trên Form;
    else (Có)
      |Control (Xử lý Hệ thống)|
      :Xử lý lưu trữ tệp tin Hình ảnh;
      :Lấy đường dẫn URL/Path\ncủa các ảnh vừa tải lên;

      if (Là hành động Thêm mới?) then (Đúng)
        :Khởi tạo đối tượng Product mới;
      else (Sửa)
        :Cập nhật đối tượng Product cũ;
      endif

      :Gắn thông tin cơ bản, gán ID của\nCategory, Brand và Ảnh Thumbnail;
      :Tạo các đối tượng ProductImage\nvà đưa vào danh sách ảnh của Product;

      |Entity (Cơ sở dữ liệu)|
      :Lưu đối tượng Product \n(Bao gồm cả cập nhật tồn kho, giá);
      :Lưu các đối tượng ProductImage \n(Cascade Save);

      |Control (Xử lý Hệ thống)|
      :Chuyển hướng (Redirect) về\nTrang danh sách Sản phẩm;

      |Boundary (Giao diện UI)|
      :Hiển thị thông báo\n"Lưu Sản phẩm thành công";
      stop
    endif
  endif
repeat while (Có lỗi xảy ra?) is (Có)

@enduml