@startuml
!theme plain
skinparam classAttributeIconSize 0
skinparam linetype ortho

package utesoundshop {

    enum UserRole {
        customer
        admin
    }

    enum UserStatus {
        active
        locked
        pending
    }

    enum OrderStatus {
        PENDING
        PROCESSING
        SHIPPED
        DELIVERED
        CANCELLED
    }

    interface PaymentStrategy <<interface>> {
        + pay(amount: BigDecimal): void
    }

    class CODStrategy {
        + pay(amount: BigDecimal): void
    }

    class StorePickupStrategy {
        + pay(amount: BigDecimal): void
    }

    class BankTransferStrategy {
        + pay(amount: BigDecimal): void
    }

    PaymentStrategy <|.. CODStrategy
    PaymentStrategy <|.. StorePickupStrategy
    PaymentStrategy <|.. BankTransferStrategy

    enum DiscountType {
        PERCENTAGE
        FIXED_AMOUNT
    }

    enum VoucherStatus {
        ACTIVE
        INACTIVE
        EXPIRED
    }

    class User {
        - Long id
        - String username
        - String fullName
        - String email
        - String passwordHash
        - String phoneNumber
        - UserRole role
        - UserStatus status
        - LocalDateTime createdAt
        - LocalDateTime updatedAt
    }

    class Address {
        - Long id
        - String recipientName
        - String phoneNumber
        - String streetAddress
        - String province
        - String provinceCode
        - String ward
        - String wardCode
        - Boolean isDefault
        - LocalDateTime createdAt
        - LocalDateTime updatedAt
    }

    class Brand {
        - Long id
        - String name
        - String description
        - String logoUrl
        - LocalDateTime createdAt
        - LocalDateTime updatedAt
    }

    class Category {
        - Long id
        - String name
        - String description
        - LocalDateTime createdAt
        - LocalDateTime updatedAt
    }

    class Product {
        - Long id
        - String name
        - String description
        - BigDecimal price
        - String thumbnailUrl
        - String specifications
        - Boolean status
        - LocalDateTime createdAt
        - LocalDateTime updatedAt
    }

    class Inventory {
        - Long id
        - Integer stockQuantity
        - LocalDateTime updatedAt
    }

    class ProductImage {
        - Long id
        - String imageUrl
        - String altText
        - Boolean isPrimary
        - LocalDateTime createdAt
    }

    class Cart {
        - Long id
        - LocalDateTime createdAt
        - LocalDateTime updatedAt
    }

    class CartItem {
        - Long id
        - Integer quantity
        - LocalDateTime createdAt
        - LocalDateTime updatedAt
    }

    class Order {
        - Long id
        - String orderCode
        - String email
        - String recipientName
        - String phoneNumber
        - String streetAddress
        - String city
        - OrderStatus status
        - PaymentStrategy paymentStrategy
        - BigDecimal totalAmount
        - LocalDateTime createdAt
        - LocalDateTime updatedAt
    }

    class OrderItem {
        - Long id
        - Integer quantity
        - LocalDateTime createdAt
    }

    class Voucher {
        - Long id
        - String code
        - DiscountType discountType
        - BigDecimal discountValue
        - Integer maxUsage
        - BigDecimal minOrderValue
        - LocalDateTime expiryDate
        - VoucherStatus status
        - LocalDateTime createdAt
        - LocalDateTime updatedAt
    }

    class Review {
        - Long id
        - Integer rating
        - String comment
        - LocalDateTime createdAt
        - LocalDateTime updatedAt
    }

    class ReviewLike {
        - Long id
        - LocalDateTime createdAt
    }

    ' === 1. COMPOSITION (*-->) Hình thoi đặc: Áp dụng cho CascadeType.ALL ===
    User "1" *--> "*" Address : has
    User "1" *--> "1" Cart : owns
    User "1" *--> "*" Order : places
    User "1" *--> "*" Review : writes
    Cart "1" *--> "*" CartItem : contains
    Order "1" *--> "*" OrderItem : contains
    Product "1" *--> "*" ProductImage : has
    Product "1" *--> "1" Inventory : manages stock
    Product "1" *--> "*" Review : receives
    Review "1" *--> "*" ReviewLike : receives
    Category "1" *--> "*" Category : parent/children
    Category "1" *--> "*" Product : contains
    Brand "1" *--> "*" Product : manufactures
    'Voucher "1" *--> "*" Order : applied to

    ' === 2. AGGREGATION (o-->) Hình thoi rỗng: Tập hợp ===
    OrderItem "*" o--> "1" Product : references
    Order o--> PaymentStrategy : uses

    ' === 3. ASSOCIATION (--> hoặc --) Mũi tên thường hoặc đường thẳng: Liên kết tham chiếu ===
    CartItem "*" --> "1" Product : references
    Voucher "1" -- "*" Order : applied to
    ReviewLike "*" --> "1" User : liked by

    
    'Review "*" --> "1" Product : about

    ' === 4. DEPENDENCY (..>) Nét đứt: Phụ thuộc Enum ===
    User ..> UserRole
    User ..> UserStatus
    Order ..> OrderStatus
    Voucher ..> DiscountType
    Voucher ..> VoucherStatus
}
@enduml