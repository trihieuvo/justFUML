@startuml
!theme plain
skinparam SequenceMessageAlign center
skinparam linetype ortho

actor User
boundary UI
control OrderController
control OrderService
control VoucherService
entity Database

User -> UI : Nhập thông tin & voucherCode\nNhấn "Đặt hàng"
activate UI

UI -> OrderController : POST /api/v1/checkout\n(Gửi JSON payload)
activate OrderController

OrderController -> OrderController : Parse JSON (lấy voucherCode, shippingInfo...)

OrderController -> OrderService : checkout(userId, shippingInfo, voucherCode, ...)
activate OrderService

OrderService -> VoucherService : validateVoucher(voucherCode, orderTotal, userId)
activate VoucherService

VoucherService -> Database : Truy vấn Voucher bằng Code
activate Database
Database --> VoucherService : Trả về dữ liệu Voucher
deactivate Database

VoucherService -> VoucherService : Kiểm tra (Status, Expiry, MaxUsage, MinOrderValue)

alt Nếu Voucher hợp lệ
    VoucherService --> OrderService : Trả về VoucherValidationResult (hợp lệ)
else Nếu Voucher không hợp lệ
    VoucherService --> OrderService : Trả về VoucherValidationResult (báo lỗi)
end
deactivate VoucherService

alt Validation thành công
    OrderService -> VoucherService : calculateDiscount(voucher, orderTotal)
    activate VoucherService
    VoucherService --> OrderService : Trả về số tiền giảm (discount)
    deactivate VoucherService

    OrderService -> OrderService : Tính finalAmount = totalAmount - discount
    OrderService -> Database : Lưu thông tin Order và OrderItem
    activate Database
    Database --> OrderService : Thành công
    deactivate Database

    OrderService --> OrderController : Trả về thông tin đơn hàng
    OrderController --> UI : HTTP 201 Created (Thành công)
else Validation thất bại
    OrderService --> OrderController : throw RuntimeException(Lỗi voucher)
    OrderController --> UI : HTTP 400 Bad Request (Lỗi)
end
deactivate OrderService
deactivate OrderController

UI --> User : Hiển thị kết quả đơn hàng / Lỗi
deactivate UI

@enduml