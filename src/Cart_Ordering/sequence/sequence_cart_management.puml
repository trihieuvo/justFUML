@startuml
!theme plain
skinparam SequenceMessageAlign center
skinparam linetype ortho

title Sequence Diagram - Quản lý Giỏ hàng (CRUD CartItem)

actor User
boundary UI
control CartController
control CartService
entity CartRepository
entity ProductRepository

' ==========================================
' LUỒNG 1: THÊM SẢN PHẨM VÀO GIỎ HÀNG
' ==========================================
group Thêm sản phẩm (Add Item)
    User -> UI : Nhấn "Thêm vào giỏ"
    activate UI

    UI -> CartController : POST /api/cart/add
    activate CartController

    CartController -> CartService : addItemToCart(userId, productId, quantity)
    activate CartService

    CartService -> CartRepository : findByUserId(userId)
    activate CartRepository
    CartRepository --> CartService : Optional<Cart>
    deactivate CartRepository

    alt Nếu Cart không tồn tại
        CartService -> CartRepository : createCartForUser(user)
        activate CartRepository
        CartRepository --> CartService : Cart mới
        deactivate CartRepository
    end

    CartService -> ProductRepository : findById(productId)
    activate ProductRepository
    ProductRepository --> CartService : Optional<Product>
    deactivate ProductRepository

    alt Nếu Tồn kho < quantity
        CartService --> CartController : throw RuntimeException(Lỗi tồn kho)
    else Nếu Tồn kho hợp lệ
        CartService -> CartRepository : findCartItem(cartId, productId)
        activate CartRepository
        CartRepository --> CartService : Optional<CartItem>
        deactivate CartRepository

        alt Sản phẩm đã có trong giỏ
            CartService -> CartService : Tính số lượng mới
            CartService -> CartRepository : saveCartItem(item)
            activate CartRepository
            CartRepository --> CartService : Thành công
            deactivate CartRepository
        else Sản phẩm chưa có trong giỏ
            CartService -> CartRepository : saveCartItem(newItem)
            activate CartRepository
            CartRepository --> CartService : Thành công
            deactivate CartRepository
        end

        CartService -> CartService : buildCartResponse(cart)
        CartService --> CartController : Trả về dữ liệu giỏ hàng
    end

    CartController --> UI : HTTP 200 OK / 400 Bad Request
    deactivate CartService
    deactivate CartController

    UI --> User : Cập nhật giỏ hàng / Báo lỗi
    deactivate UI
end

' ==========================================
' LUỒNG 2: XÓA SẢN PHẨM KHỎI GIỎ
' ==========================================
group Xóa sản phẩm (Remove Item)
    User -> UI : Nhấn "Xóa sản phẩm"
    activate UI

    UI -> CartController : DELETE /api/cart/remove
    activate CartController

    CartController -> CartService : removeItemFromCart(userId, productId)
    activate CartService

    CartService -> CartRepository : findByUserId(userId)
    CartService -> CartRepository : findCartItem(cartId, productId)

    CartService -> CartRepository : deleteCartItem(itemId)
    activate CartRepository
    CartRepository --> CartService : Thành công
    deactivate CartRepository

    CartService -> CartService : buildCartResponse(cart)
    CartService --> CartController : Trả về dữ liệu giỏ hàng mới

    CartController --> UI : HTTP 200 OK
    deactivate CartService
    deactivate CartController

    UI --> User : Giao diện đã xóa sản phẩm
    deactivate UI
end
@enduml