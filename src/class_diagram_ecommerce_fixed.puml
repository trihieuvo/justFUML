@startuml
!theme plain
skinparam classAttributeIconSize 0
skinparam linetype ortho

package utesoundshop {

    enum UserRole {
        customer
        admin
    }

    enum UserStatus {
        active
        locked
        pending
    }

    enum OrderStatus {
        PENDING
        PROCESSING
        SHIPPPING
        DELIVERED
        CANCELLED
    }


    enum DiscountType {
        PERCENTAGE
        FIXED_AMOUNT
    }

    enum VoucherStatus {
        ACTIVE
        INACTIVE
        EXPIRED
    }

class User {
- Long userID
- String username
- String fullName
- String email
- String passwordHash
- String phoneNumber
- UserRole role
- UserStatus status
- LocalDateTime createdAt
- LocalDateTime updatedAt
}

class Address {
- Long addressID
- String recipientName
- String phoneNumber
- String streetAddress
- String province
- String provinceCode
- String ward
- String wardCode
- Boolean isDefault
- LocalDateTime createdAt
- LocalDateTime updatedAt
}

class Brand {
- Long brandID
- String name
- String description
- String logoUrl
- LocalDateTime createdAt
- LocalDateTime updatedAt
}

class Category {
- Long categoryID
- String name
- String description
- LocalDateTime createdAt
- LocalDateTime updatedAt
}

class Product {
- Long productID
- String name
- String description
- BigDecimal price
- String thumbnailUrl
- String specifications
- Boolean status
- LocalDateTime createdAt
- LocalDateTime updatedAt
}

class Inventory {
- Long inventoryID
- Integer stockQuantity
- LocalDateTime createdAt
- LocalDateTime updatedAt
}

class ProductImage {
- Long imageID
- String imageUrl
- String altText
- Boolean isPrimary
- LocalDateTime createdAt
}

class Cart {
- Long cartID
- LocalDateTime createdAt
- LocalDateTime updatedAt
}

class CartItem {
- Long cartItemID
- Integer quantity
- LocalDateTime createdAt
- LocalDateTime updatedAt
}

class Order {
- Long orderID
- String orderCode
- String email
- String recipientName
- String phoneNumber
- String address
- OrderStatus status
- BigDecimal totalAmount
- LocalDateTime createdAt
- LocalDateTime updatedAt
}

class OrderItem {
- Long orderItemID
- Integer quantity
- LocalDateTime createdAt
}

class Voucher {
- Long voucherID
- String code
- DiscountType discountType
- BigDecimal discountValue
- Integer maxUsage
- BigDecimal minOrderValue
- LocalDateTime expiryDate
- VoucherStatus status
- LocalDateTime createdAt
- LocalDateTime updatedAt
}

class Review {
- Long reviewID
- Integer rating
- String comment
- LocalDateTime createdAt
- LocalDateTime updatedAt
}

class ReviewLike {
- Long reviewLikeID
- LocalDateTime createdAt
}

    ' === 1. COMPOSITION (*-->) Hình thoi đặc: Áp dụng cho CascadeType.ALL ===

    Cart "1" *--> "*" CartItem : contains
    Order "1" *--> "*" OrderItem : contains
    Product "1" *--> "*" ProductImage : has
    Category "1" *--> "*" Category : parent/children



    ' === 3. ASSOCIATION (--> hoặc --) Mũi tên thường hoặc đường thẳng: Liên kết tham chiếu ===
    CartItem "*" --> "1" Product : references
    Voucher "1" --> "*" Order : applied to
    ReviewLike "*" --> "1" User : liked by
    Product "1" --> "1" Inventory : managed by
    User "1" --> "1" Cart : owns
    User "1" --> "*" Address : has
    User "1" --> "*" Order : places
    Product "1" --> "*" Review : receives
    Brand "1" --> "*" Product : manufactures
    OrderItem "*" --> "1" Product : references
    Review "1" --> "*" ReviewLike : receives
    Category "1" --> "*" Product : contains
    User "1" --> "*" Review : writes

    ' === 4. DEPENDENCY (..>) Nét đứt: Phụ thuộc Enum ===
    User ..> UserRole
    User ..> UserStatus
    Order ..> OrderStatus
    Voucher ..> DiscountType
    Voucher ..> VoucherStatus
}
@enduml