@startuml
skinparam ClassAttributeIconSize 0
left to right direction
skinparam ranksep 50
skinparam nodesep 30

' --- Observer Interface ---
interface OrderNotificationService <<Observer>> {
  + notifyProcessing(order : Order)
  + notifyShipping(order : Order)
  + notifyDelivered(order : Order)
  + notifyCancelled(order : Order, reason : String)
}

' --- Concrete Observer ---
class OrderNotificationServiceImpl <<ConcreteObserver>> {
  - emailService : EmailService
  - thymeleafConfig : ThymeleafConfig
  --
  + OrderNotificationServiceImpl()
  + notifyProcessing(order : Order)
  + notifyShipping(order : Order)
  + notifyDelivered(order : Order)
  + notifyCancelled(order : Order, reason : String)
}

' --- Subject (Publisher) ---
class CheckoutServiceImpl <<Subject>> {
  - orderNotificationService : OrderNotificationService
  --
  + checkout(userId : Long, request : CheckoutRequest) : CheckoutResponse
}

' --- Dependencies ---
class EmailService <<Helper>> {
  + sendHtmlEmail(to, subject, html)
}

class ThymeleafConfig <<Helper>> {
  + getTemplateEngine() : TemplateEngine
}

' --- Data Entity ---
class Order {
    - id : Long
    - orderCode : String
    - status : OrderStatus
    - email : String
    - ...
}

' --- Relationships ---
OrderNotificationService <|.. OrderNotificationServiceImpl : "implements"
OrderNotificationServiceImpl --> EmailService : "sends via"
OrderNotificationServiceImpl --> ThymeleafConfig : "renders via"
CheckoutServiceImpl o--> "1" OrderNotificationService : "notifies"
OrderNotificationService ..> Order : "handles"
ThymeleafConfig ..> Order : "templates with"

note top of OrderNotificationServiceImpl
  **Observer cụ thể:** Render template HTML bằng Thymeleaf,
  sau đó gửi email qua EmailService.
  Tách biệt hoàn toàn khỏi logic database.

  Có try-catch để không ảnh hưởng luồng chính.
  Bao gồm việc tính discount từ voucher.
end note

note top of CheckoutServiceImpl
  **Khi checkout thành công:**
  orderNotificationService
  .notifyProcessing(order)
  → Gửi email xác nhận ngay.
end note

note bottom of OrderNotificationServiceImpl
  **QUAN TRỌNG:** OrderNotificationServiceImpl
  thuộc Observer Pattern, không liên quan đến
  OrderContext (thuộc State Pattern).
end note

@enduml
