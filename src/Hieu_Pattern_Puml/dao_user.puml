@startuml
skinparam ClassAttributeIconSize 0

' --- DAO Interface ---
interface UserDAO <<DAO Interface>> {
    + findByEmail(email : String) : Optional<User>
    + findByUsername(username : String) : Optional<User>
    + findByUsernameOrEmail(identifier : String) : Optional<User>
    + findByPhoneNumber(phone : String) : Optional<User>
    + findById(id : Long) : Optional<User>
    + save(user : User) : User
    + findAll() : List<User>
    + search(keyword, role, status) : List<User>
    + search(keyword, role, status, offset, limit) : List<User>
    + countSearch(keyword, role, status) : long
}

' --- Concrete DAO ---
class UserDAOImpl <<DAO Implementation>> {
    - {static} instance : UserDAOImpl
    --
    + {static} synchronized getInstance() : UserDAOImpl
    + findByEmail(email : String) : Optional<User>
    + findByUsername(username : String) : Optional<User>
    + save(user : User) : User
    + search(keyword, role, status, offset, limit) : List<User>
    + ...
}

' --- Entity ---
class User <<Entity>> {
    - id : Long
    - username : String
    - fullName : String
    - email : String
    - passwordHash : String
    - phoneNumber : String
    - role : UserRole
    - status : UserStatus
    - createdAt : LocalDateTime
    - updatedAt : LocalDateTime
}

' --- Database ---
class DatabaseConfig <<Infrastructure>> {
    + {static} getInstance() : DatabaseConfig
    + getEntityManager() : EntityManager
}

' --- Clients ---
class AuthFacade <<Client>> {
    - userService : UserService
}

class CheckoutServiceImpl <<Client>> {
    - userDAO : UserDAO
}

' --- Relationships ---
UserDAO <|.. UserDAOImpl : "implements"
UserDAOImpl ..> DatabaseConfig : "getEntityManager()"
UserDAOImpl ..> User : "<<persists / queries>>"
AuthFacade ..> UserDAO : "uses (via UserService)"
CheckoutServiceImpl ..> UserDAO : "uses directly"

' --- Notes ---
note bottom of UserDAO
  **DAO Pattern (Data Access Object)**
  Tách biệt hoàn toàn logic truy cập 
  Database (JPQL, EntityManager) 
  khỏi tầng Service / Business Logic.
  
  Các client chỉ gọi method trên 
  interface mà không biết bên trong 
  dùng JPA, JDBC hay framework gì.
end note

note right of UserDAOImpl
  Sử dụng JPA EntityManager 
  để thực thi JPQL query.
  Kết hợp Singleton để đảm bảo 
  chỉ có 1 instance duy nhất.
end note

@enduml
