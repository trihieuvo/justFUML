@startuml
skinparam ClassAttributeIconSize 0
skinparam wrapWidth 250
skinparam spacing 50
top to bottom direction

' --- Abstract Class ---
abstract class OrderCommand <<Command>> {
    # facade : OrderFacade
    # templateEngine : ITemplateEngine
    # application : JakartaServletWebApplication
    + init(facade: OrderFacade, templateEngine: ITemplateEngine, application: JakartaServletWebApplication) : void
    + {abstract} execute(req: HttpServletRequest, resp: HttpServletResponse) : void
    # render(req: HttpServletRequest, resp: HttpServletResponse, template: String, context: WebContext) : void
    # createWebContext(req: HttpServletRequest, resp: HttpServletResponse) : WebContext
}

' --- Interfaces ---
interface OrderFacade <<Facade>> {
    + getOrdersByOrderCodes(orderCodes: List<String>) : List<Order>
    + getOrderByOrderCode(orderCode: String) : Order
}

' --- Concrete Commands ---
class TrackOrderCommand <<ConcreteCommand>> {
    + execute(req: HttpServletRequest, resp: HttpServletResponse) : void
}

' --- Factory ---
class OrderCommandFactory <<Factory>> {
    - {static} commands : Map<String, OrderCommand>
    + {static} getCommand(method: String, path: String) : OrderCommand
}

' --- Client / Controller ---
class OrderTrackingController <<Invoker>> {
    - orderFacade : OrderFacade
    - templateEngine : ITemplateEngine
    - application : JakartaServletWebApplication
    + init() : void
    # doGet(req: HttpServletRequest, resp: HttpServletResponse) : void
    # doPost(req: HttpServletRequest, resp: HttpServletResponse) : void
    - processRequest(req: HttpServletRequest, resp: HttpServletResponse) : void
}

' --- Subsystems ---
class OrderServiceImpl <<Subsystem>>
class PaymentServiceImpl <<Subsystem>>

' --- Relationships ---
OrderCommand <|-- TrackOrderCommand : "<<extends>>"
OrderTrackingController ..> OrderCommandFactory : "<<uses>>"
OrderCommandFactory ..> OrderCommand : "<<creates>>"
OrderTrackingController *--> "1" OrderFacade : "<<manages lifecycle>>"
OrderCommand o--> "1" OrderFacade : "<<uses>>"
OrderFacade ..> OrderServiceImpl : "<<delegates>>"
OrderFacade ..> PaymentServiceImpl : "<<delegates>>"

note bottom of OrderTrackingController
  **Invoker Controller**
  Khởi tạo OrderFacade.
  Quản trị vòng đời (Composition).
end note

note bottom of OrderCommandFactory
  **Factory Method**
  Sử dụng Map để phân bổ luồng
  thành đối tượng Command.
end note

note bottom of OrderCommand
  **Abstract Command**
  Sở hữu sẵn Facade và view engine.
end note

@enduml
