@startuml
skinparam ClassAttributeIconSize 0
skinparam wrapWidth 250
skinparam spacing 50
top to bottom direction

' --- Abstract Class ---
abstract class ProfileCommand <<Command>> {
    # facade : UserProfileFacade
    # templateEngine : ITemplateEngine
    # application : JakartaServletWebApplication
    + init(facade: UserProfileFacade, templateEngine: ITemplateEngine, application: JakartaServletWebApplication) : void
    + {abstract} execute(req: HttpServletRequest, resp: HttpServletResponse, userId: Long) : void
    # render(req: HttpServletRequest, resp: HttpServletResponse, template: String, context: WebContext) : void
    # createWebContext(req: HttpServletRequest, resp: HttpServletResponse) : WebContext
}

' --- Interface ---
interface UserProfileFacade <<Facade>> {
    + getUserDetails(userId: Long) : User
    + updateProfile(userId: Long, fullName: String, phoneNumber: String) : void
    + updateAvatar(userId: Long, avatarPart: Part) : void
    + changePassword(userId: Long, currentPassword: String, newPassword: String, confirmNewPassword: String) : void
    + getUserAddresses(userId: Long) : List<Address>
    + addAddress(userId: Long, address: Address) : void
    + updateAddress(userId: Long, address: Address) : void
    + deleteAddress(addressId: Long) : void
    + setDefaultAddress(userId: Long, addressId: Long) : void
    + getUserOrders(userId: Long) : List<Order>
    + cancelUserOrder(userId: Long, orderId: Long) : void
    + extractAddressFromRequest(req: HttpServletRequest) : Address
}

' --- Concrete Commands ---
class EditAddressCommand <<ConcreteCommand>> {
    + execute(req: HttpServletRequest, resp: HttpServletResponse, userId: Long) : void
}
class AddAddressCommand <<ConcreteCommand>> {
    + execute(req: HttpServletRequest, resp: HttpServletResponse, userId: Long) : void
}
class DeleteAddressCommand <<ConcreteCommand>> {
    + execute(req: HttpServletRequest, resp: HttpServletResponse, userId: Long) : void
}
class SetDefaultAddressCommand <<ConcreteCommand>> {
    + execute(req: HttpServletRequest, resp: HttpServletResponse, userId: Long) : void
}

' --- Factory ---
class ProfileCommandFactory <<Factory>> {
    - {static} getCommands : Map<String, ProfileCommand>
    - {static} postCommands : Map<String, ProfileCommand>
    + {static} getCommand(method: String, path: String) : ProfileCommand
}

' --- Client / Controller ---
class UserProfileController <<Invoker>> {
    - profileFacade : UserProfileFacade
    - templateEngine : ITemplateEngine
    - application : JakartaServletWebApplication
    + init() : void
    # doGet(req: HttpServletRequest, resp: HttpServletResponse) : void
    # doPost(req: HttpServletRequest, resp: HttpServletResponse) : void
    - processRequest(req: HttpServletRequest, resp: HttpServletResponse) : void
}

' --- Subsystems ---
class AddressServiceImpl <<Subsystem>>
class UserServiceImpl <<Subsystem>>

' --- Relationships ---
ProfileCommand <|-- EditAddressCommand
ProfileCommand <|-- AddAddressCommand
ProfileCommand <|-- DeleteAddressCommand
ProfileCommand <|-- SetDefaultAddressCommand

UserProfileController ..> ProfileCommandFactory : "<<uses>>"
ProfileCommandFactory ..> ProfileCommand : "<<creates>>"
UserProfileController *--> "1" UserProfileFacade : "<<manages lifecycle>>"
ProfileCommand o--> "1" UserProfileFacade : "<<uses>>"
UserProfileFacade ..> AddressServiceImpl : "<<delegates>>"
UserProfileFacade ..> UserServiceImpl : "<<delegates>>"

note bottom of UserProfileController
  **Invoker Controller**
  Khởi tạo UserProfileFacade.
  Route request bằng Factory thay vì if/else.
end note

note bottom of ProfileCommandFactory
  **Factory Method**
  Sinh object tuỳ route (/address/edit,...)
end note

note bottom of UserProfileFacade
  **Facade Layer**
  Xử lý logic raw request và uỷ thác 
  vào Service chính xác.
end note

@enduml
