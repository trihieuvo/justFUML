@startuml
!theme plain
skinparam linetype ortho
skinparam shadowing false
skinparam roundcorner 5
skinparam class {
    BackgroundColor white
    ArrowColor #263238
    BorderColor #263238
}

entity "User" as User {
    * id : BIGINT <<PK>>
    --
    * username : VARCHAR(50)
    * full_name : VARCHAR(100)
    * email : VARCHAR(100)
    password_hash : VARCHAR
    phone_number : VARCHAR(20)
    * role : ENUM
    * status : ENUM
    avatar : VARCHAR
    created_at : TIMESTAMP
    updated_at : TIMESTAMP
}

entity "Address" as Address {
    * id : BIGINT <<PK>>
    --
    * user_id : BIGINT <<FK>>
    * recipient_name : VARCHAR(100)
    * phone_number : VARCHAR(20)
    * street_address : TEXT
    * province : VARCHAR(100)
    * district : VARCHAR(100)
    * ward : VARCHAR(100)
    is_default : BOOLEAN
}

entity "Category" as Category {
    * id : BIGINT <<PK>>
    --
    * name : VARCHAR(100)
    description : TEXT
    parent_id : BIGINT <<FK>>
}

entity "Brand" as Brand {
    * id : BIGINT <<PK>>
    --
    * name : VARCHAR(100)
    description : TEXT
    logo_url : VARCHAR(500)
}

entity "Product" as Product {
    * id : BIGINT <<PK>>
    --
    * name : VARCHAR(200)
    description : TEXT
    * price : DECIMAL(12,2)
    thumbnail_url : VARCHAR(500)
    specifications : JSONB
    * category_id : BIGINT <<FK>>
    * brand_id : BIGINT <<FK>>
    * stock_quantity : INTEGER
    status : BOOLEAN
}

entity "ProductImage" as ProductImage {
    * id : BIGINT <<PK>>
    --
    * product_id : BIGINT <<FK>>
    * image_url : VARCHAR(500)
    alt_text : VARCHAR(200)
    is_primary : BOOLEAN
}

entity "Cart" as Cart {
    * id : BIGINT <<PK>>
    --
    * user_id : BIGINT <<FK>>
}

entity "CartItem" as CartItem {
    * id : BIGINT <<PK>>
    --
    * cart_id : BIGINT <<FK>>
    * product_id : BIGINT <<FK>>
    * quantity : INTEGER
}

entity "Order" as Order {
    * id : BIGINT <<PK>>
    --
    * order_code : VARCHAR(50)
    user_id : BIGINT <<FK>>
    * email : VARCHAR(100)
    * recipient_name : VARCHAR(100)
    * phone_number : VARCHAR(20)
    * street_address : TEXT
    * total_amount : DECIMAL(12,2)
    voucher_id : BIGINT <<FK>>
    * status : ENUM
    payment_method : VARCHAR
}

entity "OrderItem" as OrderItem {
    * id : BIGINT <<PK>>
    --
    * order_id : BIGINT <<FK>>
    * product_id : BIGINT <<FK>>
    * quantity : INTEGER
    * price : DECIMAL(12,2)
}

entity "Review" as Review {
    * id : BIGINT <<PK>>
    --
    * user_id : BIGINT <<FK>>
    * product_id : BIGINT <<FK>>
    * rating : INTEGER
    comment : TEXT
}

entity "ReviewLike" as ReviewLike {
    * id : BIGINT <<PK>>
    --
    * user_id : BIGINT <<FK>>
    * review_id : BIGINT <<FK>>
}

entity "Voucher" as Voucher {
    * id : BIGINT <<PK>>
    --
    * code : VARCHAR(50)
    * discount_type : ENUM
    * discount_value : DECIMAL(12,2)
    min_order_value : DECIMAL(12,2)
    expiry_date : TIMESTAMP
}

' Relationships
User ||--o{ Address
User |o--|| Cart
User ||--o{ Order
User ||--o{ Review
User ||--o{ ReviewLike

Cart ||--o{ CartItem
Product ||--o{ CartItem

Product }|--|| Category
Product }|--|| Brand
Product ||--o{ ProductImage
Product ||--o{ Review
Product ||--o{ OrderItem

Order ||--o{ OrderItem
Order }o..o| Voucher

Review ||--o{ ReviewLike

Category ||--o{ Category : "parent"

@enduml
