@startuml
!theme plain
autonumber
skinparam maxMessageSize 150
skinparam ParticipantPadding 20
skinparam BoxPadding 10

title Sơ đồ tuần tự (Sequence Diagram) - Luồng Đổi mật khẩu (Change Password)

actor "Người dùng" as User
participant "Giao diện (UI)" as UI
participant "UserController" as Controller
participant "UserService" as Service
participant "UserDAO" as DAO
database "PostgreSQL\n(Database)" as DB

User -> UI : Nhập mật khẩu cũ, mật khẩu mới\nNhấn "Lưu thay đổi"
activate UI

UI -> Controller : POST /user/change-password\n(oldPass, newPass)
activate Controller

Controller -> Service : changePassword(userId, request)
activate Service

Service -> DAO : findById(userId)
activate DAO
DAO -> DB : SELECT * FROM users WHERE id
activate DB
DB --> DAO : User Data
deactivate DB
DAO --> Service : Thu được User object
deactivate DAO

Service -> Service : BCrypt.checkpw(oldPass, user.hash)
alt Sai mật khẩu cũ
    Service --> Controller : Ném ngoại lệ (Mật khẩu cũ không khớp)
    Controller --> UI : Báo lỗi
    UI --> User : Hiển thị lỗi xác thực
else Đúng mật khẩu cũ
    Service -> Service : BCrypt.hashpw(newPass)
    Service -> DAO : updatePassword(userId, newHash)
    activate DAO
    DAO -> DB : UPDATE users SET password
    activate DB
    DB --> DAO : Thành công
    deactivate DB
    DAO --> Service : Done
    deactivate DAO

    Service --> Controller : Cập nhật thành công
    Controller --> UI : Thông báo thành công
    UI --> User : Hiển thị thông báo hoàn tất
end

deactivate Service
deactivate Controller
deactivate UI

@enduml
