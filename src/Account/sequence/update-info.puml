@startuml
!theme plain
autonumber
skinparam SequenceMessageAlign center
skinparam ParticipantPadding 20
skinparam BoxPadding 10
skinparam linetype ortho

title Sequence Diagram - Cập nhật thông tin/Địa chỉ (Java Servlet & JPA)

actor "Thành viên (User)" as User
boundary "Giao diện (UI / JSP)" as UI
control "AddressServlet" as Servlet
control "AddressService" as Service
entity "AddressDAO (JPA)" as DAO
database "Database" as DB

User -> UI : Điền form địa chỉ & Tích "Đặt làm mặc định"\nNhấn "Lưu"
activate UI

alt Luồng: Thêm địa chỉ mới (POST)
    UI -> Servlet : AJAX POST /api/addresses\n(JSON payload)
    activate Servlet

    Servlet -> Servlet : Đọc JSON từ HttpServletRequest\nLấy userId từ Session/JWT

    Servlet -> Service : addAddress(userId, addressDTO)
    activate Service

    Service -> Service : em.getTransaction().begin()
    Service -> Service : Map DTO sang Entity Address mới

else Luồng: Cập nhật địa chỉ (PUT)
    UI -> Servlet : AJAX PUT /api/addresses?id={id}\n(JSON payload)

    Servlet -> Servlet : Đọc JSON từ HttpServletRequest\nLấy userId từ Session/JWT

    Servlet -> Service : updateAddress(addressId, userId, addressDTO)

    Service -> Service : em.getTransaction().begin()

    Service -> DAO : findByIdAndUserId(addressId, userId)
    activate DAO
    DAO --> Service : Managed Entity (Address)
    deactivate DAO

    alt Không tìm thấy hoặc Không thuộc quyền sở hữu
        Service -> Service : em.getTransaction().rollback()
        Service --> Servlet : throw CustomException("Not Found / Forbidden")
        Servlet --> UI : HTTP 404 / 403 (JSON Error)
        UI --> User : Hiển thị thông báo lỗi
    else Dữ liệu hợp lệ
        Service -> Service : Cập nhật các trường (streetAddress, ward...)
    end
end

' --- LOGIC XỬ LÝ ĐỊA CHỈ MẶC ĐỊNH ---
alt Nếu addressDTO.isDefault == true
    Service -> DAO : findDefaultAddress(userId)
    activate DAO
    DAO -> DB : SELECT * FROM addresses\nWHERE user_id = ? AND is_default = true
    activate DB
    DB --> DAO : oldDefaultAddress
    deactivate DB
    DAO --> Service : oldDefaultAddress
    deactivate DAO

    opt Nếu tồn tại oldDefaultAddress
        Service -> Service : oldDefaultAddress.setIsDefault(false)
        Service -> DAO : merge(oldDefaultAddress)
        activate DAO
        DAO -> DB : UPDATE addresses SET is_default = false
        activate DB
        DB --> DAO : Success
        deactivate DB
        DAO --> Service : Success
        deactivate DAO
    end

    Service -> Service : addressToSave.setIsDefault(true)
else Nếu addressDTO.isDefault == false
    Service -> Service : addressToSave.setIsDefault(false)
end

' --- LƯU THAY ĐỔI VÀ ĐÓNG TRANSACTION ---
alt Là thao tác Thêm mới
    Service -> DAO : persist(addressToSave)
else Là thao tác Cập nhật
    Service -> DAO : merge(addressToSave)
end

activate DAO
DAO -> DB : INSERT / UPDATE
activate DB
DB --> DAO : Success
deactivate DB
DAO --> Service : savedAddress
deactivate DAO

Service -> Service : em.getTransaction().commit()

Service --> Servlet : AddressDTO (Dữ liệu đã lưu)
deactivate Service

Servlet -> Servlet : Chuyển AddressDTO thành JSON\nGhi vào HttpServletResponse
Servlet --> UI : HTTP 200 OK / 201 Created (JSON Response)
deactivate Servlet

UI --> User : Thông báo "Lưu thành công"\n& Cập nhật danh sách địa chỉ trên màn hình
deactivate UI

@enduml