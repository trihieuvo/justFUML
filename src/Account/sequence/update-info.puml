@startuml
!theme plain
autonumber
skinparam SequenceMessageAlign center
skinparam ParticipantPadding 20
skinparam BoxPadding 10
skinparam linetype ortho

title Sequence Diagram - Cập nhật thông tin/Địa chỉ (Thêm/Sửa & Đặt mặc định)

actor "Thành viên (User)" as User
boundary "Giao diện (UI)" as UI
control "AddressController" as Controller
control "AddressService" as Service
entity "AddressRepository" as Repo
database "Database" as DB

User -> UI : Điền thông tin địa chỉ\n(Tên, SĐT, Đường, Xã, Tỉnh, Đặt làm mặc định)\nNhấn "Lưu"
activate UI

alt Luồng: Thêm địa chỉ mới
    UI -> Controller : POST /api/v1/addresses\n(JSON payload: AddressRequest)
    activate Controller

    Controller -> Service : addAddress(userId, request)
    activate Service

    Service -> Service : Khởi tạo đối tượng Address mới\nMap thông tin từ request (recipientName, phoneNumber...)

else Luồng: Cập nhật địa chỉ hiện tại
    UI -> Controller : PUT /api/v1/addresses/{id}\n(JSON payload: AddressRequest)

    Controller -> Service : updateAddress(addressId, userId, request)

    Service -> Repo : findByIdAndUserId(addressId, userId)
    activate Repo
    Repo --> Service : Optional<Address>
    deactivate Repo

    alt Không tìm thấy địa chỉ (hoặc không thuộc về User)
        Service --> Controller : throw Exception("Không tìm thấy địa chỉ")
        Controller --> UI : HTTP 404/403 Lỗi truy cập
        UI --> User : Hiển thị thông báo lỗi
    else Tìm thấy địa chỉ hợp lệ
        Service -> Service : Cập nhật các trường (streetAddress, ward, province...)
    end
end

' --- XỬ LÝ LOGIC ĐỊA CHỈ MẶC ĐỊNH ---
alt Nếu người dùng chọn isDefault = true
    Service -> Repo : findDefaultAddressByUserId(userId)
    activate Repo
    Repo -> DB : SELECT * FROM addresses\nWHERE user_id = ? AND is_default = true
    activate DB
    DB --> Repo : Kết quả (oldDefaultAddress)
    deactivate DB
    Repo --> Service : Trả về oldDefaultAddress (nếu có)
    deactivate Repo

    opt Nếu tồn tại địa chỉ mặc định cũ (oldDefaultAddress != null)
        Service -> Service : oldDefaultAddress.setIsDefault(false)

        Service -> Repo : save(oldDefaultAddress)
        activate Repo
        Repo -> DB : UPDATE addresses SET is_default = false
        activate DB
        DB --> Repo : Thành công
        deactivate DB
        Repo --> Service : Trả về kết quả
        deactivate Repo
    end

    Service -> Service : addressToSave.setIsDefault(true)
else Nếu isDefault = false
    Service -> Service : addressToSave.setIsDefault(false)
end

' --- LƯU ĐỊA CHỈ VÀO DATABASE ---
Service -> Repo : save(addressToSave)
activate Repo
Repo -> DB : INSERT / UPDATE vào bảng addresses
activate DB
DB --> Repo : Thành công
deactivate DB
Repo --> Service : Trả về Address đã được lưu
deactivate Repo

Service --> Controller : Trả về AddressResponse
deactivate Service

Controller --> UI : HTTP 200 OK / 201 Created (Kèm AddressResponse)
deactivate Controller

UI --> User : Hiển thị thông báo "Lưu địa chỉ thành công"\n& Cập nhật lại danh sách địa chỉ trên UI
deactivate UI

@enduml