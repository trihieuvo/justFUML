@startuml
!theme plain
skinparam linetype ortho
skinparam ActivityBackgroundColor #f9f9f9
skinparam ActivityBorderColor #333333

title Activity Diagram - Luồng Quên mật khẩu

|Khách hàng|
start
:Truy cập trang "Quên mật khẩu";

repeat
  :Nhập địa chỉ Email;
  :Yêu cầu gửi mã OTP;

  |Hệ thống|
  :Kiểm tra Email tồn tại (DB);
  if (Email hợp lệ?) then (Không)
    :Hiển thị lỗi "Email không tồn tại";
    |Khách hàng|
    if (Tiếp tục thử lại?) then (Không)
      stop
    endif
  else (Có)
    |Hệ thống|
    :Tạo mã OTP & Lưu vào Redis;
    :Gửi mã OTP qua Email;

    |Khách hàng|
    :Chuyển đến trang "Xác thực OTP";

    repeat
      :Nhập mã OTP;
      :Nhấn "Xác nhận";

      |Hệ thống|
      :Kiểm tra mã OTP;
      if (OTP hợp lệ?) then (Không)
        :Hiển thị lỗi "Mã OTP sai hoặc hết hạn";
        |Khách hàng|
        if (Tiếp tục thử lại?) then (Không)
          stop
        endif
      else (Có)
        |Hệ thống|
        :Xác thực thành công;

        |Khách hàng|
        :Chuyển đến trang "Đặt lại mật khẩu";

        repeat
          :Nhập Mật khẩu mới;
          :Nhấn "Lưu thay đổi";

          |Hệ thống|
          :Kiểm tra định dạng (Validation);
          if (Hợp lệ?) then (Không)
            :Hiển thị lỗi định dạng;
            |Khách hàng|
            if (Tiếp tục thử lại?) then (Không)
              stop
            endif
          else (Có)
            |Hệ thống|
            :Mã hóa mật khẩu mới (Hash);
            :Cập nhật vào Database;
            :Xóa mã OTP (Redis);
            :Thông báo đổi mật khẩu thành công;

            |Khách hàng|
            :Chuyển hướng về trang Đăng nhập;
            stop
          endif
        repeat while (Mật khẩu chưa hợp lệ?) is (Đúng)
      endif
    repeat while (OTP chưa hợp lệ?) is (Đúng)
  endif
repeat while (Email không tồn tại?) is (Đúng)

@enduml