@startuml
title Sơ đồ Hoạt động Quên mật khẩu - AudioGear E-Commerce

skinparam ActivityStartColor white
skinparam ActivityEndColor white

|Khách hàng|
start
:Truy cập trang "Quên mật khẩu";
:Nhập địa chỉ Email;
:Nhấn nút "Gửi mã xác nhận";

|Hệ thống|
:Kiểm tra Email trong Cơ sở dữ liệu;
if (Email tồn tại?) then (Không)
    :Báo lỗi "Email không tồn tại";
    stop
else (Có)
    :Kiểm tra giới hạn gửi tin (Anti-spam/Cooldown);
    if (Được phép gửi?) then (Không)
        :Yêu cầu đợi 1 phút;
        stop
    else (Có)
        :Tạo mã OTP ngẫu nhiên;
        :Lưu mã OTP vào Redis (Hết hạn sau 5 phút);
        :Gửi mã OTP qua Email cho khách hàng;
    endif
endif

|Khách hàng|
:Nhập mã OTP nhận được từ Email;
:Nhấn "Xác minh mã";

|Hệ thống|
:Kiểm tra mã OTP trong Redis;
if (Mã hợp lệ?) then (Không)
    :Tăng số lần nhập sai;
    :Báo lỗi "Mã xác nhận không đúng hoặc hết hạn";
    if (Sai quá 5 lần?) then (Có)
        :Khóa tính năng trong 30 phút;
    endif
    stop
else (Có)
    :Xác nhận mã thành công;
endif

|Khách hàng|
:Nhập mật khẩu mới;
:Xác nhận lại mật khẩu;
:Nhấn "Đổi mật khẩu";

|Hệ thống|
:Kiểm tra định dạng mật khẩu;
:Mã hóa mật khẩu mới (Bcrypt/Hash);
:Cập nhật mật khẩu mới vào Database;
:Xóa mã OTP và số lần thử sai trong Redis;
:Chuyển hướng về trang Đăng nhập;

|Khách hàng|
:Nhận thông báo thành công và Đăng nhập lại;

stop
@enduml