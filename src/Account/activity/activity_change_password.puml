@startuml
title Sơ đồ Hoạt động Đổi mật khẩu - AudioGear E-Commerce

skinparam ActivityStartColor white
skinparam ActivityEndColor white

|Người dùng|
start
:Truy cập trang Đổi mật khẩu;
:Nhập (Mật khẩu cũ, Mật khẩu mới, Xác nhận mật khẩu mới);
:Nhấn nút "Lưu thay đổi";

|Hệ thống|
:Tiếp nhận yêu cầu (UserController);
:Kiểm tra User đang đăng nhập (Session/Token);
if (Chưa đăng nhập?) then (Có)
    :Chuyển hướng Đăng nhập;
    stop
else (Không)
    :Xác thực mật khẩu cũ (BCrypt);
    if (Đúng mật khẩu cũ?) then (Không)
        :Báo lỗi mật khẩu cũ không đúng;
        stop
    else (Có)
        if (Mật khẩu mới trùng khớp xác nhận?) then (Không)
            :Báo lỗi xác nhận không khớp;
            stop
        else (Có)
            :Mã hóa mật khẩu mới (BCrypt);
            :Cập nhật vào Database;
            :Ghi log thay đổi;
            :Thông báo đổi thành công;
        endif
    endif
endif

|Người dùng|
:Nhận thông báo cập nhật thành công;

stop
@enduml
